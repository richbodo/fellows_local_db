[Unit]
Description=Fellows PWA distribution server
After=network.target

[Service]
Type=simple
User={{ deploy_user }}
Group={{ deploy_user }}
WorkingDirectory={{ app_root }}/deploy
ExecStart=/usr/bin/python3 {{ app_root }}/deploy/server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
